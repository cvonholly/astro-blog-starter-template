---
// src/pages/index.astro
// You can import your layout component here if you have one
// import Layout from '../layouts/Layout.astro';

const pageTitle = "Carl von Holly-Ponientzietz | Energy & Engineering";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <style>
      /* Add some basic lively styles here or use your global CSS/Tailwind */
      body { font-family: 'Fira Sans', sans-serif; line-height: 1.6; color: #304263; max-width: 900px; margin: 0 auto; padding: 2rem; }
      h1, h2, h3 { color: #304263; }
      .hero { text-align: center; margin-bottom: 3rem; }
      .section { margin-bottom: 2.5rem; }
      .tag { background: #e2e8f0; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.9rem; margin-right: 0.5rem; display: inline-block; margin-bottom: 0.5rem;}
      .highlight { font-weight: bold; color: #e11d48; }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <h1>Hi, I'm Carl von Holly-Ponientzietz [cite: 7] 👋</h1>
        <p class="subtitle">Electrical Engineer | Energy Markets Enthusiast | Climate Tech Advocate</p>
        <p>
          I am passionate about addressing challenges in the energy sector through engineering innovation and policy design[cite: 8]. Based in Zurich [cite: 11], I specialize in renewable energy data analytics and techno-economic modeling[cite: 7, 8].
        </p>
        <div class="contact-links">
          <a href="mailto:cvonholly@ikmail.com">Email Me [cite: 11]</a> | 
          <a href="https://github.com/cvonholly">GitHub [cite: 11]</a> | 
          <a href="https://www.linkedin.com/in/cvonholly/">LinkedIn [cite: 11]</a>
        </div>
      </section>

      <section class="section">
        <h2>🎓 My Academic Journey</h2>
        <p>I am currently an MSc candidate in Energy Science and Technology at ETH Zurich (2024-2026)[cite: 18]. My studies dive deep into Power Systems, Control Systems, Optimization, Game Theory, and Energy Markets[cite: 21].</p>
        <ul>
          <li><strong>Master's Thesis:</strong> "A Coalitional Stable and Fair Reward Allocation for Dynamic Virtual Power Plants"[cite: 20]. I achieved a 6.0 (the highest possible grade) for proposing a new allocation scheme and control design for distributed energy resources[cite: 20].</li>
          <li><strong>Project with EPG:</strong> I applied Natural Language Processing and Information Theory to patent data to measure the complexity of low-carbon energy technologies[cite: 21, 22]. I even presented this at the Conference on Economic Complexity[cite: 21]!</li>
          <li><strong>BSc Electrical Engineering:</strong> Also from ETH Zurich (2020-2023), where I wrote my thesis on "Optimal Battery Parameterization for Peak Load Reduction"[cite: 22, 23].</li>
        </ul>
      </section>

      <section class="section">
        <h2>💻 What I Do (Professionally)</h2>
        <div class="job">
          <h3>Photovoltaic Data Analytics Intern @ candi solar [cite: 25]</h3>
          <p><em>Zurich and South Africa | Sept 2023 - Mar 2024 [cite: 25]</em></p>
          <ul>
            <li>Developed automated issue detection pipelines in Python and AWS, drastically reducing reaction time to solar plant faults[cite: 25].</li>
            <li>Designed and deployed performance monitoring dashboards using Looker Studio, Python, and AWS for a fleet of commercial PV plants[cite: 25, 26].</li>
          </ul>
        </div>
        <div class="job">
          <h3>Teaching & Research @ ETH Zurich [cite: 26, 27]</h3>
          <ul>
            <li><strong>Teaching Assistant:</strong> Supported over 150 students in Control Systems and Electronic Circuits[cite: 26].</li>
            <li><strong>Research Assistant (HVL):</strong> Implemented code in Python and MATLAB to analyze circuit breaker insulation equipment[cite: 27].</li>
          </ul>
        </div>
      </section>

      <section class="section">
        <h2>🌍 Tech for Good & Policy</h2>
        <ul>
          <li><strong>Hackathon for Climate Change (OpenAI):</strong> I developed a Chrome extension using a GPT model to classify green jobs and compare green skills[cite: 28].</li>
          <li><strong>Mini Makeathon (ETH4D):</strong> Prototyped movable cooling rooftops for Bangladesh[cite: 28].</li>
          <li><strong>Policy Sprint Member:</strong> Collaborated with stakeholders in Luzern to formulate policies aimed at making the Swiss transportation sector climate-neutral by 2050[cite: 28].</li>
        </ul>
      </section>

      <section class="section">
        <h2>🛠️ My Toolbox</h2>
        <div>
          <span class="tag">Python [cite: 12]</span>
          <span class="tag">MATLAB [cite: 12]</span>
          <span class="tag">SQL [cite: 12]</span>
          <span class="tag">Git [cite: 12]</span>
          <span class="tag">AWS (Lambda, EC2) [cite: 13]</span>
          <span class="tag">Looker Studio [cite: 13]</span>
          <span class="tag">LaTeX [cite: 13]</span>
        </div>
      </section>

      <section class="section">
        <h2>🚴 Off the Clock</h2>
        <p>When I'm not coding or analyzing energy markets, I like to stay active and give back to the community:</p>
        <ul>
          <li><strong>Community:</strong> I'm the founder of the D-ITET Netto Null Arbeitsgruppe and an active ambassador for foodsharing Zurich, managing daily operations with six co-ambassadors[cite: 14, 28].</li>
          <li><strong>On the Move:</strong> You can catch me delivering organic fruits through the city as a bike messenger for Öpfelchasper[cite: 29]. I'm also a road cycling coach at ASVZ and enjoy ski touring in AACZ[cite: 15].</li>
          <li><strong>Music:</strong> I play the trombone in a symphony orchestra[cite: 16]!</li>
        </ul>
      </section>
    </main>
  </body>
</html>